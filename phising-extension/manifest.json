{
  "manifest_version": 3,

  "name": "AI Phishing Detector",

  "version": "1.0",

  "description": "Detect phishing websites using AI",

  "permissions": ["tabs", "activeTab", "storage"],

  "host_permissions": ["<all_urls>", "http://127.0.0.1:5000/*"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Phishing Detector"
  },

  "icons": {
    "128": "icon.png"
  }
}
